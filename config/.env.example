# Veridicta - Configuration
# Copier ce fichier vers .env et remplir les valeurs

# ---------- LLM Backend ----------
# "cerebras" (default, gratuit) ou "copilot" (GitHub Copilot)
LLM_BACKEND=cerebras

# --- Cerebras ---
CEREBRAS_API_KEY=

# --- GitHub Copilot (si LLM_BACKEND=copilot) ---
# PAT avec scope `copilot`, ou `gh auth login` en fallback
GITHUB_PAT=
COPILOT_MODEL=gpt-4.1

# ---------- Scraping ----------
SCRAPE_DELAY_SECONDS=1.0
