# Veridicta - Configuration
# Copier ce fichier vers .env et remplir les valeurs

# Groq API (LLM generation) - https://console.groq.com/keys
GROQ_API_KEY=

# HuggingFace Inference API (embeddings) - https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Scraping (optionnel)
SCRAPE_DELAY_SECONDS=1.0
