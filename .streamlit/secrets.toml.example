# Veridicta — Streamlit Cloud secrets template
# Copy this file content into: Streamlit Cloud > App settings > Secrets
# Do NOT commit .streamlit/secrets.toml (already gitignored)

# Cerebras Cloud API key — https://cloud.cerebras.ai
CEREBRAS_API_KEY = "csk-..."

# GitHub PAT for Copilot backend (optional — only needed if LLM_BACKEND=copilot)
GITHUB_PAT = "github_pat_..."

# HuggingFace token (read access) — https://huggingface.co/settings/tokens
# Required to download the index artifacts from Fascinax/veridicta-index
HF_API_TOKEN = "hf_..."

# Optional overrides
# LLM_BACKEND = "cerebras"   # or "copilot"
# LLM_MODEL   = "gpt-oss-120b"
